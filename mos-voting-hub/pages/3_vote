import streamlit as st
from utils.db import fetch_ideas, fetch_votes, insert_vote, has_voted

st.title("🗳️ Vote on Ideas")

ideas = fetch_ideas()
if not ideas:
    st.info("No ideas yet.")
    st.stop()

idea_options = {idea["name"]: idea["id"] for idea in ideas}
selected_name = st.selectbox("Select an idea to vote on", options=list(idea_options.keys()))
idea_id = idea_options[selected_name]

if has_voted(idea_id, st.session_state.get("voter_name")):
    st.warning("You have already voted on this idea.")
    st.stop()

st.subheader(f"Voting on: {selected_name}")

col1, col2 = st.columns(2)
with col1:
    cost = st.slider("Cost (0 free → 5 needs sponsorship)", 0, 5, 2, help="0 = free, 2 = self fundable, 5 = outside sponsorship")
    complexity = st.slider("Complexity (0 simple → 5 full cloud integrations)", 0, 5, 2, help="0 = no dependencies, 5 = complex architecture")
    resourcing = st.slider("Resourcing (0 one person → 5 full team)", 0, 5, 2, help="0 = single developer, 5 = resource intensive")
with col2:
    revenue = st.slider("Revenue Potential (0 none → 5 high financial return)", 0, 5, 3, help="Focus on business financial upside")
    fit = st.slider("Strategic Fit (0 low → 5 perfect alignment)", 0, 5, 3, help="Alignment with Mapped Out Solutions goals")

comment = st.text_area("Comments (optional)")

voter_name = st.selectbox("Your name", st.secrets["TEAM_MEMBERS"])

if st.button("Submit Vote"):
    insert_vote(idea_id, voter_name, cost, complexity, resourcing, revenue, fit, comment)
    st.success("Vote recorded. Thank you!")
    st.rerun()